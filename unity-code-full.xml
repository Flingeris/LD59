    private void UpdateNightFaithCollection()
    {
        if (RunState == null || RunState.CurrentPhase != GamePhase.Night)
        {
            return;
        }
        var collectedFaith = faithCollectionSystem.UpdateCollection(RunState, Time.deltaTime);
        if (collectedFaith <= 0)
